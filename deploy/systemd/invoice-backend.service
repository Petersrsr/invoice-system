[Unit]
Description=Invoice System Backend (FastAPI)
After=network.target

[Service]
Type=simple
User=www
Group=www
WorkingDirectory=/www/wwwroot/invoice-system
ExecStart=/www/wwwroot/invoice-system/deploy/start_backend.sh
Restart=always
RestartSec=3
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
