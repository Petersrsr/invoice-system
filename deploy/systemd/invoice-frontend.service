[Unit]
# 前端预览服务（提供 Vite preview 静态页面）。
Description=Invoice System Frontend (Vite Preview)
After=network.target

[Service]
Type=simple
User=www
Group=www
WorkingDirectory=/www/wwwroot/invoice-system
ExecStart=/www/wwwroot/invoice-system/deploy/start_frontend.sh
Restart=always
RestartSec=3
Environment=NODE_ENV=production
# 允许非 root 用户绑定 1024 以下端口（如 80）。
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE

[Install]
WantedBy=multi-user.target
